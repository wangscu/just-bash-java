{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "just-bash": ["../../src/index.ts"]
    }
  },
  "include": ["*.ts", "../../src/**/*.ts"],
  "exclude": ["node_modules"]
}
